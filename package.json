{
  "name": "shipit-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck",
    "setup": "bash scripts/setup.sh",
    "start:infra": "bash scripts/infra.sh",
    "start:backend": "bash scripts/infra.sh && turbo dev --filter=@shipit-ai/api-server --filter=@shipit-ai/core-writer",
    "start:frontend": "turbo dev --filter=@shipit-ai/web-ui",
    "start:mcp": "turbo dev --filter=@shipit-ai/mcp-server",
    "start:all": "bash scripts/infra.sh && turbo dev",
    "seed": "npx tsx scripts/seed-demo.ts",
    "stop": "docker compose -f docker/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.5.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  }
}
